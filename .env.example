# Zephyr Scale Cloud API token (JWT bearer). Generate in Jira:
#   profile menu -> "Zephyr API keys". Required.
ZEPHYR_API_TOKEN=

# Optional. API region. One of: us (default), eu, au, de.
# Ignored if ZEPHYR_BASE_URL is set.
ZEPHYR_REGION=us

# Optional. Full base URL override (takes precedence over ZEPHYR_REGION).
# ZEPHYR_BASE_URL=https://api.zephyrscale.smartbear.com/v2
